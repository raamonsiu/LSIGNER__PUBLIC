# ======================================== #
# ====   EXAMPLE OF ENVIRONMENT FILE  ==== #
# ======================================== #

# = The comments in this file are not aligned with the variables they refer to, 
# == to avoid causing errors in environment readers.

# = Depending on which library or tool is reading the variables, 
# == you'll need to escape characters such as the comment character ‘#’ 
# == or the equals sign ‘=’. It's a good idea to read the documentation for that tool.

# ========================== #
# ====  APPLICATION     ==== #
# ========================== #
APP_NAME=LSigner
APP_PORT=3000
# APP_ENV is the canonical environment flag for this app (development|production)
APP_ENV=development
# NODE_ENV should mirror APP_ENV — required by Node.js tooling (Jest, ts-node, etc.)
NODE_ENV=development

# ========================== #
# =======  CORS     ======== #
# ========================== #
# Comma-separated list of allowed frontend origins.
# Development default: http://localhost:3001
# Add production domain when deploying: CORS_ORIGINS=http://localhost:3001,https://lsigner.example.com
CORS_ORIGINS=http://localhost:3001

# ========================== #
# ===== DATABASE    ======== #
# ========================== #
# When running with Docker via docker-compose.dev.yml, DB_HOST is overridden to 'db'.
# When running locally without Docker, set DB_HOST=localhost
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=lsb_dev_local
# DB_SSL should be 'true' or 'false'. In production, set to true if using SSL.
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED Set to 'false' to allow self-signed certificates (not recommended for production)
DB_SSL_REJECT_UNAUTHORIZED=true
# Optional: enable TypeORM logging in development only
DB_LOGGING=false

# ========================== #
# ======= TypeORM   ======== #
# ========================== #
# TYPEORM_SYNC: never set to true in production — use migrations instead
TYPEORM_SYNC=false

# ========================== #
# ========  OTP  =========== #
# ========================== #
# OTP_TTL_SECONDS: OTP code validity in seconds (default: 300 = 5 min)
OTP_TTL_SECONDS=300
# OTP_LENGTH: number of digits (default: 6)
OTP_LENGTH=6
# OTP_MAX_ATTEMPTS: max failed attempts (default: 5)
OTP_MAX_ATTEMPTS=5
# OTP_LOCK_MINUTES: lock duration after max attempts (default: 15)
OTP_LOCK_MINUTES=15
# OTP_RESEND_COOLDOWN_SECONDS: cooldown between resends (default: 60)
OTP_RESEND_COOLDOWN_SECONDS=60
# OTP_MAX_RESENDS: max resends per challenge (default: 3)
OTP_MAX_RESENDS=3

# ============================= #
# =====  AUTHENTICATION  ====== #
# ============================= #
# JWT_SECRET: secret used to sign & verify access tokens.
#   Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   REQUIRED in all environments. Never use the placeholder value in production.
JWT_SECRET=change-me-to-a-long-random-secret
# JWT_EXPIRES_IN: access token lifetime (jsonwebtoken format: '15m', '1h', '7d')
JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN: refresh token lifetime stored in the DB
JWT_REFRESH_EXPIRES_IN=7d

# ========================================= #
# =====  Document Signing (Ed25519)  ====== #
# ========================================= #
# Generate keys with: (read line below or ask LLM how to)
#   node -e "const c=require('crypto');const {privateKey,publicKey}=c.generateKeyPairSync('ed25519');const pp=privateKey.export({type:'pkcs8',format:'pem'});const pup=publicKey.export({type:'spki',format:'pem'});console.log('DOCUMENT_SIGNING_PRIVATE_KEY='+Buffer.from(pp).toString('base64'));console.log('DOCUMENT_SIGNING_PUBLIC_KEY='+Buffer.from(pup).toString('base64'))"
# Store the output in your .env file. Never commit real keys.
DOCUMENT_SIGNING_PRIVATE_KEY=
DOCUMENT_SIGNING_PUBLIC_KEY=

# =========================== #
# =====  Email (SMTP)  ====== #
# =========================== #
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your-smtp-user
EMAIL_PASSWORD=your-smtp-password
EMAIL_FROM=whatever@lsigner.com
EMAIL_FROM_NAME=LSigner
EMAIL_SECURE=false
EMAIL_DEBUG=false
EMAIL_TLS_REJECT_UNAUTHORIZED=true
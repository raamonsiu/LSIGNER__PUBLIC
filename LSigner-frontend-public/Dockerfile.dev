FROM node:20-alpine

WORKDIR /app

# Install system Chromium (compiled for musl : compatible with Alpine)
RUN apk add --no-cache chromium

# Playwright v1.61.0 expects chromium_headless_shell-1228 at this exact path
# Symlink Alpine's Chromium so Playwright finds it at its expected location
RUN mkdir -p /root/.cache/ms-playwright/chromium_headless_shell-1228/chrome-headless-shell-linux64 && \
    ln -sf /usr/lib/chromium/chromium \
      /root/.cache/ms-playwright/chromium_headless_shell-1228/chrome-headless-shell-linux64/chrome-headless-shell

ENV PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=true

CMD ["sh"]
